# MKTR Frontend Environment Configuration

# Backend API URL - Set to your production API domain for prod builds
VITE_API_URL=http://localhost:3001/api
VITE_API_BASE=/api
VITE_USE_GATEWAY=true

# Environment
VITE_NODE_ENV=development

# App Configuration
VITE_APP_NAME=MKTR Marketing Platform
VITE_APP_VERSION=1.0.0

# Upload-size hint shown in the campaign designer (MEGABYTES) — keep in sync
# with the backend MAX_UPLOAD_SIZE_MB (default: 10 on both sides)
# VITE_MAX_UPLOAD_SIZE_MB=10

# Campaign Studio — full-viewport design_config v2 editor (Studio PR 3). Gates
# the /admin/campaigns/:id/studio route + the workspace Design-tab entry point.
# Saves ALSO need the backend DESIGN_CONFIG_V2_WRITES_ENABLED gate on.
# VITE_CAMPAIGN_STUDIO_ENABLED=false

# Google OAuth Configuration
VITE_GOOGLE_CLIENT_ID=942720017977-odeosq0qbmd9hgij0n1fmuc0vuduhj4c.apps.googleusercontent.com
