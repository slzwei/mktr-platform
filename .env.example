# =============================================================================
# MKTR Platform — Frontend (Vite) Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# All variables MUST start with VITE_ to be exposed to the browser.
# Do NOT commit .env to version control.
# =============================================================================

# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:3001/api

# Google OAuth client ID (must match the backend GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# =============================================================================
# Backend Environment Variables
# =============================================================================

# Sentry error tracking (optional)
VITE_SENTRY_DSN=

# Retell AI Voice Bot
RETELL_WEBHOOK_SECRET=         # HMAC secret for verifying inbound Retell webhooks
RETELL_API_KEY=                # API key for fetching call recordings from Retell
RETELL_AGENTS=[]               # JSON: [{"agentId":"agent_xxx","name":"Campaign Name"}]
# RETELL_CAMPAIGN_MAP=         # Optional override: retellAgentId:campaignUUID,...

# Meta Business Suite (FB/IG Lead Ads)
META_APP_SECRET=               # App secret for verifying Meta webhook signatures
META_PAGE_ACCESS_TOKEN=        # Long-lived Page Access Token for Graph API
META_VERIFY_TOKEN=             # Verify token for Meta webhook subscription handshake

# Webhook system
WEBHOOK_ENABLED=false          # Master switch — MUST be "true" for leads to reach Lyfe

# Lyfe webhook (lead forwarding — auto-registers subscriber on startup)
LYFE_WEBHOOK_URL=              # e.g. https://<project>.supabase.co/functions/v1/receive-mktr-lead
LYFE_WEBHOOK_SECRET=           # Shared HMAC secret (must match MKTR_WEBHOOK_SECRET in Supabase)

# Lyfe Supabase (agent sync)
LYFE_SUPABASE_URL=             # Supabase project URL
LYFE_SUPABASE_SERVICE_ROLE_KEY= # Service-role key (bypasses RLS)
