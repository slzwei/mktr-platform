# =============================================================================
# MKTR Platform — Frontend (Vite) Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# All variables MUST start with VITE_ to be exposed to the browser.
# Do NOT commit .env to version control.
# =============================================================================

# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:3001/api

# Google OAuth client ID (must match the backend GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# =============================================================================
# Backend Environment Variables
# =============================================================================

# Sentry error tracking (optional)
VITE_SENTRY_DSN=

# Webhook system
WEBHOOK_ENABLED=false          # Master switch for all outgoing webhooks

# Lyfe integration (agent sync)
LYFE_API_URL=                  # Lyfe's Edge Function base URL (provided by Lyfe team)
LYFE_API_KEY=                  # API key for Lyfe's agent API (provided by Lyfe team)

# Lyfe webhook (lead forwarding — auto-registers subscriber on startup)
LYFE_WEBHOOK_URL=              # e.g. https://<project>.supabase.co/functions/v1/receive-mktr-lead
LYFE_WEBHOOK_SECRET=           # Shared HMAC secret (must match MKTR_WEBHOOK_SECRET in Supabase)
