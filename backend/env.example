# Environment Configuration
NODE_ENV=development
PORT=3001

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mktr_db
DB_USER=mktr_user
DB_PASSWORD=mktr_password
# For SQLite (local dev fallback), set an absolute DATABASE_URL to avoid stray files
# Example (macOS): DATABASE_URL=/Users/yourname/Downloads/mktr/backend/fresh.db
# DATABASE_URL=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Google OAuth Configuration
GOOGLE_CLIENT_ID=942720017977-odeosq0qbmd9hgij0n1fmuc0vuduhj4c.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-from-json-file

# CORS Configuration
# redeem.sg is the public-brand sibling static site; both apex + www allowed.
CORS_ORIGIN=http://localhost:5173,https://mktr.sg,https://www.mktr.sg,https://redeem.sg,https://www.redeem.sg

# Public URL used to embed in generated QR codes (must point to a host that
# serves /t/:slug). Per D4, set to https://redeem.sg in prod so new QR codes
# encode the public brand domain. APK download URLs derived from this var
# will also route via redeem.sg/api/apk/* and be proxied through to the
# backend by Render's /api rewrite — confirm this is acceptable before flip.
PUBLIC_BASE_URL=http://localhost:3001

# Per-frontend base URLs for the dual-host setup. Used by trackerController +
# leadCaptureBind to redirect users back to the SPA on the same public host
# they came from. Internal-only flows (invite emails, admin emails, OAuth
# callback) keep using FRONTEND_BASE_URL / MKTR_FRONTEND_URL.
MKTR_FRONTEND_URL=https://mktr.sg
REDEEM_FRONTEND_URL=https://redeem.sg

# Gateway internal URL for leadgen proxy shim
GATEWAY_INTERNAL_URL=http://gateway:4000

# Email Configuration (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads/

# Redis Configuration (optional)
REDIS_HOST=localhost
REDIS_PORT=6379

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# Phase C Flags (AdTech Manifest & Beacons)
MANIFEST_ENABLED=false
BEACONS_ENABLED=false
MANIFEST_REFRESH_SECONDS=300
MANIFEST_RPS_PER_DEVICE=2
BEACON_IDEMP_WINDOW_MIN=10
BEACON_RPS_PER_DEVICE=5

# System Agent Defaults
SYSTEM_AGENT_EMAIL=system@mktr.local
# Redirect System Agent lead-assignment emails to this address (skipped if unset)
# SYSTEM_AGENT_REDIRECT_EMAIL=admin@example.com
# Optional: Pin a default active agent id; if invalid, email fallback is used
# DEFAULT_AGENT_ID=

# AWS SNS (SMS Verification)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
# Optional: Sender ID (e.g. "MKTR"). Leave blank to use shared/default routes.
AWS_SNS_SENDER_ID=

# Meta WhatsApp Cloud API
WHATSAPP_PROVIDER=meta
META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=
META_WA_BUSINESS_ACCOUNT_ID=

# =============================================================================
# Lead Pipeline (Retell → MKTR → Lyfe)
# =============================================================================

# Retell AI Voice Bot
RETELL_WEBHOOK_SECRET=your-retell-webhook-secret
RETELL_API_KEY=your-retell-api-key
# JSON array: [{"agentId":"agent_xxx","name":"Campaign Name"}]
RETELL_AGENTS=[]
# Optional: retellAgentId:campaignUUID,...
# RETELL_CAMPAIGN_MAP=

# Webhook dispatch — MUST be "true" for leads to reach Lyfe
WEBHOOK_ENABLED=false
# Edge function URL for receive-mktr-lead
LYFE_WEBHOOK_URL=https://<project>.supabase.co/functions/v1/receive-mktr-lead
# Shared HMAC secret (must match MKTR_WEBHOOK_SECRET in Supabase edge function)
LYFE_WEBHOOK_SECRET=your-shared-webhook-secret

# Lyfe Supabase (agent sync)
LYFE_SUPABASE_URL=https://<project>.supabase.co
LYFE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# mktr-leads (second agent source — mirrored into `users` exactly like Lyfe).
# All four OPTIONAL; unset = inert. Sync env-gated on MKTR_LEADS_SUPABASE_URL.
MKTR_LEADS_SUPABASE_URL=https://<project>.supabase.co
MKTR_LEADS_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
MKTR_LEADS_WEBHOOK_URL=https://<project>.supabase.co/functions/v1/receive-mktr-lead
MKTR_LEADS_WEBHOOK_SECRET=your-shared-webhook-secret
