# =============================================================================
# MKTR Platform — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
# Set to "true" behind a reverse proxy (Nginx, Cloudflare, etc.)
TRUST_PROXY=false

# -----------------------------------------------------------------------------
# Database — PostgreSQL (omit all DB_* vars to fall back to SQLite)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mktr_dev
DB_USER=postgres
DB_PASSWORD=your-db-password-here
# Force SSL on/off (auto-enabled in production if omitted)
# DB_SSL=true
# SQLite fallback path (used when DB_HOST is not set)
# DATABASE_URL=fresh.db

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=your-jwt-secret-here
# Token lifetime (default: 24h)
JWT_EXPIRES_IN=24h

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Optional for public clients
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Explicit redirect URI (optional — derived from FRONTEND_BASE_URL if omitted)
# GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# -----------------------------------------------------------------------------
# URLs
# -----------------------------------------------------------------------------
# Frontend origin used for invite links, redirects, etc.
FRONTEND_BASE_URL=http://localhost:5173
# Alias used in some auth routes (falls back to FRONTEND_BASE_URL)
FRONTEND_URL=http://localhost:5173
# Public backend URL used for QR codes and tracking links
PUBLIC_BASE_URL=http://localhost:3001
# CORS allowed origins (comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Branding
# -----------------------------------------------------------------------------
COMPANY_NAME=MKTR
COMPANY_URL=https://your-company-url.com

# -----------------------------------------------------------------------------
# Email (SMTP via Nodemailer)
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=you@example.com
EMAIL_PASSWORD=your-email-password-here
# From address (defaults to EMAIL_USER if omitted)
# EMAIL_FROM=noreply@example.com

# -----------------------------------------------------------------------------
# Twilio (phone verification)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=your-twilio-verify-service-sid

# -----------------------------------------------------------------------------
# DigitalOcean Spaces (file storage / CDN)
# -----------------------------------------------------------------------------
DO_SPACES_KEY=your-spaces-access-key
DO_SPACES_SECRET=your-spaces-secret-key
DO_SPACES_REGION=nyc3
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_BUCKET=your-bucket-name
DO_SPACES_CDN_BASE=https://your-bucket-name.nyc3.cdn.digitaloceanspaces.com

# -----------------------------------------------------------------------------
# Uploads
# -----------------------------------------------------------------------------
# Max file size in bytes (default: 10 MB)
# MAX_FILE_SIZE=10485760

# -----------------------------------------------------------------------------
# Security / Tracking
# -----------------------------------------------------------------------------
# Salt for hashing visitor IPs in tracking pixels
# IP_HASH_SALT=your-random-salt-here
# HMAC secret for attribution cookie signatures
# ATTRIB_SECRET=your-attrib-secret-here

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Window in milliseconds (default: 15 min in prod)
# RATE_LIMIT_WINDOW_MS=900000
# Max requests per window (default: 200 in prod)
# RATE_LIMIT_MAX_REQUESTS=200

# -----------------------------------------------------------------------------
# System Defaults
# -----------------------------------------------------------------------------
# Pre-assigned agent ID for leads without an agent
# DEFAULT_AGENT_ID=
# Email used to create/find the system agent record
# SYSTEM_AGENT_EMAIL=system@mktr.local
# Redirect System Agent lead-assignment emails to this address (skipped if unset)
# SYSTEM_AGENT_REDIRECT_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# Retell AI Voice Bot Integration
# -----------------------------------------------------------------------------
# HMAC secret for verifying inbound Retell webhook signatures
RETELL_WEBHOOK_SECRET=your-retell-webhook-secret
# API key for fetching call recordings from Retell
RETELL_API_KEY=your-retell-api-key
# JSON array of Retell agents — auto-creates [Retell] campaigns on startup
# Format: [{"agentId":"agent_xxx","name":"Campaign Name"}]
RETELL_AGENTS=[]
# Optional: override campaign resolution per Retell agent (comma-separated)
# Format: retellAgentId:campaignUUID,...
# RETELL_CAMPAIGN_MAP=

# -----------------------------------------------------------------------------
# Meta Business Suite (FB/IG Lead Ads)
# -----------------------------------------------------------------------------
# App secret for verifying inbound Meta webhook signatures (X-Hub-Signature-256)
META_APP_SECRET=your-meta-app-secret
# Long-lived Page Access Token for fetching lead data from Graph API
META_PAGE_ACCESS_TOKEN=your-meta-page-access-token
# Verify token for Meta webhook subscription handshake
META_VERIFY_TOKEN=your-meta-verify-token

# -----------------------------------------------------------------------------
# Webhook Integration (lead forwarding to Lyfe)
# -----------------------------------------------------------------------------
# Master switch — MUST be "true" for leads to reach Lyfe
WEBHOOK_ENABLED=false
# Edge function URL for receive-mktr-lead
LYFE_WEBHOOK_URL=https://<project>.supabase.co/functions/v1/receive-mktr-lead
# Shared HMAC secret (must match MKTR_WEBHOOK_SECRET in Supabase edge function)
LYFE_WEBHOOK_SECRET=your-shared-webhook-secret

# -----------------------------------------------------------------------------
# Lyfe Supabase (agent sync)
# -----------------------------------------------------------------------------
# Supabase project URL for fetching agent data
LYFE_SUPABASE_URL=https://<project>.supabase.co
# Service-role key (bypasses RLS — keep secret)
LYFE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Sentry Error Tracking (optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
