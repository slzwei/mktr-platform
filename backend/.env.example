# =============================================================================
# MKTR Platform — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
# Set to "true" behind a reverse proxy (Nginx, Cloudflare, etc.)
TRUST_PROXY=false

# -----------------------------------------------------------------------------
# Database — PostgreSQL (omit all DB_* vars to fall back to SQLite)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mktr_dev
DB_USER=postgres
DB_PASSWORD=your-db-password-here
# Force SSL on/off (auto-enabled in production if omitted)
# DB_SSL=true
# SQLite fallback path (used when DB_HOST is not set)
# DATABASE_URL=fresh.db

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=your-jwt-secret-here
# Dedicated master secret used to AES-256-GCM encrypt admin-entered AI API keys.
AI_SETTINGS_ENCRYPTION_KEY=
# Optional server-managed provider credentials. Admin-entered keys take precedence.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Token lifetime (default: 24h)
JWT_EXPIRES_IN=24h

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Optional for public clients
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Explicit redirect URI (optional — derived from FRONTEND_BASE_URL if omitted)
# GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# -----------------------------------------------------------------------------
# URLs
# -----------------------------------------------------------------------------
# Frontend origin used for invite links, redirects, etc.
FRONTEND_BASE_URL=http://localhost:5173
# Alias used in some auth routes (falls back to FRONTEND_BASE_URL)
FRONTEND_URL=http://localhost:5173
# Public backend URL used for QR codes and tracking links
PUBLIC_BASE_URL=http://localhost:3001
# CORS allowed origins (comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Branding
# -----------------------------------------------------------------------------
COMPANY_NAME=MKTR
COMPANY_URL=https://your-company-url.com

# -----------------------------------------------------------------------------
# Email (SMTP via Nodemailer)
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=you@example.com
EMAIL_PASSWORD=your-email-password-here
# From address (defaults to EMAIL_USER if omitted)
# EMAIL_FROM=noreply@example.com

# -----------------------------------------------------------------------------
# OTP / phone verification
# -----------------------------------------------------------------------------
# SMS OTP is sent via AWS SNS (the default channel). WhatsApp OTP (via Meta) is
# optional and only used for campaigns whose design_config.otpChannel='whatsapp'.
# If the Meta vars are missing or a WhatsApp send fails, it falls back to SMS.

# AWS SNS — SMS delivery
# Shared pair (also carries SES). Prefer the SNS-only pair below.
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-southeast-1
# AWS SNS sender ID — REQUIRED for +65 SG: must be the SSIR-registered ID (case-
# sensitive) or SG telcos relabel the sender "Likely-SCAM". Code defaults to "MKTR".
AWS_SNS_SENDER_ID=MKTR

# Least-privilege SNS-only IAM user. Set BOTH or NEITHER — a half-set pair is
# ignored and the shared AWS_* pair is used instead.
SNS_AWS_ACCESS_KEY_ID=
SNS_AWS_SECRET_ACCESS_KEY=

# SMS abuse controls (SGNIC SSIR User Agreement cl. 2.3.2) — /api/verify/send is
# public, and every message it sends carries the registered "MKTR" sender ID.
# Full runbook: docs/reference/sms-sender-id-compliance.md
SMS_DAILY_CAP_PER_PHONE=7
SMS_DAILY_GLOBAL_CAP=500
SMS_DAILY_ALERT_THRESHOLD=250
SMS_ALERT_EMAIL=
# Optional HMAC salt for blinding phone numbers in counter keys (falls back to JWT_SECRET)
SMS_QUOTA_SALT=

# Meta WhatsApp Cloud API — WhatsApp OTP channel (optional)
# From WhatsApp Manager → API setup. Requires an APPROVED Authentication
# template (default name 'auth_otp', language 'en_US') with an OTP button.
# META_WA_PHONE_NUMBER_ID=
# META_WA_ACCESS_TOKEN=
# Optional overrides (sensible defaults applied in code):
# META_WA_TEMPLATE_NAME=auth_otp
# META_WA_TEMPLATE_LANG=en_US
# META_GRAPH_API_VERSION=v21.0

# -----------------------------------------------------------------------------
# DigitalOcean Spaces (file storage / CDN)
# -----------------------------------------------------------------------------
DO_SPACES_KEY=your-spaces-access-key
DO_SPACES_SECRET=your-spaces-secret-key
DO_SPACES_REGION=nyc3
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_BUCKET=your-bucket-name
DO_SPACES_CDN_BASE=https://your-bucket-name.nyc3.cdn.digitaloceanspaces.com

# -----------------------------------------------------------------------------
# Uploads
# -----------------------------------------------------------------------------
# Max upload size in MEGABYTES for /api/uploads/* (images + campaign media;
# default: 10). When overriding, also set VITE_MAX_UPLOAD_SIZE_MB on every
# frontend static-site build so the editor copy matches.
# MAX_UPLOAD_SIZE_MB=10

# -----------------------------------------------------------------------------
# Security / Tracking
# -----------------------------------------------------------------------------
# Salt for hashing visitor IPs in tracking pixels
# IP_HASH_SALT=your-random-salt-here
# HMAC secret for attribution cookie signatures
# ATTRIB_SECRET=your-attrib-secret-here

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Window in milliseconds (default: 15 min in prod)
# RATE_LIMIT_WINDOW_MS=900000
# Max requests per window (default: 200 in prod)
# RATE_LIMIT_MAX_REQUESTS=200

# -----------------------------------------------------------------------------
# System Defaults
# -----------------------------------------------------------------------------
# Pre-assigned agent ID for leads without an agent
# DEFAULT_AGENT_ID=
# Email used to create/find the system agent record
# SYSTEM_AGENT_EMAIL=system@mktr.local
# Redirect System Agent lead-assignment emails to this address (skipped if unset)
# SYSTEM_AGENT_REDIRECT_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# Retell AI Voice Bot Integration
# -----------------------------------------------------------------------------
# HMAC secret for verifying inbound Retell webhook signatures
RETELL_WEBHOOK_SECRET=your-retell-webhook-secret
# API key for fetching call recordings from Retell
RETELL_API_KEY=your-retell-api-key
# JSON array of Retell agents — auto-creates [Retell] campaigns on startup
# Format: [{"agentId":"agent_xxx","name":"Campaign Name"}]
RETELL_AGENTS=[]
# Optional: override campaign resolution per Retell agent (comma-separated)
# Format: retellAgentId:campaignUUID,...
# RETELL_CAMPAIGN_MAP=

# -----------------------------------------------------------------------------
# Meta Business Suite (FB/IG Lead Ads — inbound)
# -----------------------------------------------------------------------------
# App secret for verifying inbound Meta webhook signatures (X-Hub-Signature-256)
META_APP_SECRET=your-meta-app-secret
# Long-lived Page Access Token for fetching lead data from Graph API
META_PAGE_ACCESS_TOKEN=your-meta-page-access-token
# Verify token for Meta webhook subscription handshake
META_VERIFY_TOKEN=your-meta-verify-token

# -----------------------------------------------------------------------------
# Meta Conversions API (CAPI — outbound server-side event dispatch)
# -----------------------------------------------------------------------------
# Master switch — set to "true" to dispatch Lead events to Meta
META_CAPI_ENABLED=false
# Pixel ID from Meta Business Manager → Events Manager (15-16 digits)
META_PIXEL_ID=
# Access token from Pixel → Settings → Conversions API → Generate access token
# Saved once; if lost, regenerate (old token then stops working).
META_CAPI_ACCESS_TOKEN=
# Test Event code from Pixel → Test Events tab. Set on staging; leave empty in production.
META_TEST_EVENT_CODE=
# Down-funnel custom event names fired when a Lyfe agent advances a lead.
# `qualified` means "agent CONFIRMED the lead is a Singapore Citizen/PR" (the
# liar-proof version of the self-declared form gate) → ConfirmedResident.
# `won` (bought a policy; implies SC/PR) → ConfirmedResident (if not already)
# + ClosedWon. Override only if you rename the events in Events Manager — e.g.
# set META_EVENT_WON=Purchase once a policy value is available.
META_EVENT_QUALIFIED=ConfirmedResident
META_EVENT_WON=ClosedWon

# -----------------------------------------------------------------------------
# Meta Customer-List "Redeemed" exclusion sync (outbound — Render Cron Job)
# -----------------------------------------------------------------------------
# Pushes redeemers (hashed email+phone) from the prospects table into a Meta
# Customer-List (subtype=CUSTOM) audience used as an ad-set EXCLUSION, so people
# who already redeemed stop seeing ads. Runs via RUN_MODE=cron-redeemed-audience.
# Master switch — set to "true" to enable the nightly sync.
REDEEMED_AUDIENCE_SYNC_ENABLED=false
# System User token with ads_management on the ad account (NOT the CAPI/Page token).
META_ADS_MANAGEMENT_TOKEN=
# Target Customer-List audience id (the audience the redeemers are synced into).
META_REDEEMED_AUDIENCE_ID=
# Ad account id (numeric, no act_ prefix). Only needed to create the audience or
# run a permission probe — the sync itself is audience-scoped.
META_AD_ACCOUNT_ID=
# Upload mode: "add" (additive POST /users — default, verified) or "replace"
# (POST /usersreplace — authoritative full replace; probe before relying on it).
REDEEMED_AUDIENCE_SYNC_MODE=add
# Consent gate: default true (upload only prospects with consent_contact=true).
# Set "false" to suppress ALL redeemers — a legal/DPIA decision, not an eng one.
REDEEMED_AUDIENCE_REQUIRE_CONSENT=true
# In-process schedule cadence (hours): initial run ~60s after boot, then every N hours. Default 24.
REDEEMED_AUDIENCE_SYNC_INTERVAL_HOURS=24
# Email for "bad run" alerts (hard failure or Meta-rejected records). Unset = no
# email (log + Sentry only). Sender defaults to noreply@mktr.sg.
REDEEMED_AUDIENCE_ALERT_EMAIL=
# (Graph API version is shared via META_GRAPH_API_VERSION above; defaults v21.0.)

# -----------------------------------------------------------------------------
# TikTok Events API (outbound server-side event dispatch — quiz funnel)
# -----------------------------------------------------------------------------
# Master switch — set to "true" to dispatch Lead/CompleteRegistration to TikTok
TIKTOK_EVENTS_API_ENABLED=false
# Pixel ID (pixel code) from TikTok Events Manager. Per-campaign Campaign.tiktokPixelId overrides this.
TIKTOK_PIXEL_ID=
# Access token from TikTok Events Manager → Events API → Generate access token
TIKTOK_ACCESS_TOKEN=
# Test Event code from Events Manager → Test Events. Set on staging; leave empty in production.
TIKTOK_TEST_EVENT_CODE=

# -----------------------------------------------------------------------------
# Webhook Integration (lead forwarding to Lyfe)
# -----------------------------------------------------------------------------
# Master switch — MUST be "true" for leads to reach Lyfe
WEBHOOK_ENABLED=false
# Edge function URL for receive-mktr-lead
LYFE_WEBHOOK_URL=https://<project>.supabase.co/functions/v1/receive-mktr-lead
# Shared HMAC secret (must match MKTR_WEBHOOK_SECRET in Supabase edge function)
LYFE_WEBHOOK_SECRET=your-shared-webhook-secret
# Shared HMAC secret for the REVERSE channel: Lyfe leads-outcome trigger →
# POST /api/integrations/lyfe/lead-outcome (fires down-funnel Meta CAPI events).
# Must match MKTR_LEAD_OUTCOME_SECRET in the Lyfe Supabase Vault.
LYFE_LEAD_OUTCOME_SECRET=your-lead-outcome-webhook-secret

# -----------------------------------------------------------------------------
# Lyfe Supabase (agent sync)
# -----------------------------------------------------------------------------
# Supabase project URL for fetching agent data
LYFE_SUPABASE_URL=https://<project>.supabase.co
# Service-role key (bypasses RLS — keep secret)
LYFE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# mktr-leads (second agent source — mirrored into `users` exactly like Lyfe)
# -----------------------------------------------------------------------------
# All four are OPTIONAL: leave unset and mktr-leads is fully inert (no sync, no
# subscriber). Set all four to enable. The agent sync is env-gated on
# MKTR_LEADS_SUPABASE_URL; the outbound subscriber on the WEBHOOK_URL/SECRET pair.
# Supabase project URL for fetching mktr-leads `agents` (role=agent, is_active)
MKTR_LEADS_SUPABASE_URL=https://<project>.supabase.co
# Service-role key (bypasses RLS — keep secret)
MKTR_LEADS_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Edge function URL for the mktr-leads receive-mktr-lead
MKTR_LEADS_WEBHOOK_URL=https://<project>.supabase.co/functions/v1/receive-mktr-lead
# Shared HMAC secret (must match MKTR_WEBHOOK_SECRET in the mktr-leads edge fn)
MKTR_LEADS_WEBHOOK_SECRET=your-shared-webhook-secret
# Dedicated secret for admin invites via the mktr-leads create-ext-agent-invite
# edge fn (must match its MKTR_PLATFORM_INVITE_SECRET function secret)
MKTR_LEADS_INVITE_SECRET=your-invite-service-secret

# -----------------------------------------------------------------------------
# Sentry Error Tracking (optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Lead-package billing (HitPay) — DEPLOY-INERT until BILLING_ENABLED=true
# -----------------------------------------------------------------------------
BILLING_ENABLED=false
# App-Store kill switch surfaced on the catalog: in_app | web | off
BILLING_CHECKOUT_MODE=in_app
HITPAY_API_KEY=                              # secret
HITPAY_WEBHOOK_SALT=                         # secret — webhook signature key
HITPAY_API_BASE=https://api.hit-pay.com/v1  # sandbox: https://api.sandbox.hit-pay.com/v1
HITPAY_PAYMENT_METHODS=paynow_online,card
HITPAY_WEBHOOK_URL=                          # full URL to /api/external/billing/hitpay-webhook (optional if dashboard-configured)
HITPAY_REDIRECT_URL=                         # app deep link back after pay (optional; webhook is source of truth)
# NOTE: EXTERNAL_APP_SECRET (set above) also authenticates the agent-facing billing routes.

# -----------------------------------------------------------------------------
# Agent wallet + per-campaign commitments — DEPLOY-INERT until AGENT_WALLET_ENABLED=true
# (docs/plans/agent-wallet-commitments.md). Gates /api/external/wallet (summary/
# ledger/catalog/commit). Top-ups ride /api/external/billing (kind:'wallet_topup'),
# so BILLING_ENABLED must also be true for money-in. Admin endpoints
# (/api/admin/wallets) are always mounted — admin-authed reads + audited adjustment.
# -----------------------------------------------------------------------------
AGENT_WALLET_ENABLED=false

# ── Redeem Ops — Discover tool (Apify prospecting; migration 053) ──────────────
DISCOVERY_ENABLED=false                       # master switch (also gates the reconcile sweep)
DISCOVERY_IG_ENABLED=false                    # Instagram hashtag-discovery pilot (provider kill switch; Maps stays primary)
DISCOVERY_SEARCH_TERMS_ENABLED=false          # expand category aliases in Maps searches; off preserves legacy one-name input
DISCOVERY_TERRITORIES_ENABLED=false           # admin-curated SG area picker; off preserves the free-text Area UI
DISCOVERY_RESULT_QUOTA_ENABLED=false          # atomic result/profile counters; off preserves run-count quotas
DISCOVERY_AI_TERMS_ENABLED=false              # AI keyword suggestions on Discover (needs a provider key in AdminAISettings or OPENAI_API_KEY/ANTHROPIC_API_KEY)
REDEEM_OPS_CADENCES_AI_ENABLED=false          # AI cadence drafts in the cadence editor (same provider-key requirement as above)
APIFY_TOKEN=                                  # SECRET — Apify API token
APIFY_MAPS_ACTOR_ID=compass~crawler-google-places   # Google Maps scraper actor
APIFY_INSTAGRAM_ACTOR_ID=apify~instagram-profile-scraper    # IG enrichment actor (PROFILE scraper — takes `usernames`; plain instagram-scraper does NOT)
APIFY_INSTAGRAM_HASHTAG_ACTOR_ID=apify~instagram-hashtag-scraper    # IG hashtag DISCOVERY actor (`hashtags` + `resultsLimit` input; not the enrichment actor above)
DISCOVERY_WEBHOOK_SECRET=                     # URL-path secret for the Apify terminal-event callback
DISCOVERY_WEBHOOK_BASE_URL=https://api.mktr.sg      # public base for the callback URL
DISCOVERY_MAX_RESULTS_PER_RUN=500            # per-search depth cap; 500 ≈ one whole-SG sweep of a dense category (~$3.50)
DISCOVERY_MAX_RUNS_PER_DAY=25                 # global daily cap
DISCOVERY_MAX_RUNS_PER_USER_DAY=5             # per-user cap (cost guardrail — access is all-principals)
DISCOVERY_ENRICH_MAX_PER_DAY=500             # team cap for IG enrichment, in PROFILES/day (each handle scraped = 1)
DISCOVERY_ENRICH_MAX_PER_USER_DAY=200        # per-user profile cap (same guardrail philosophy as searches)
DISCOVERY_RESULTS_PER_USER_DAY=1500          # atomic per-user SGT-day result reservation cap
DISCOVERY_RESULTS_PER_TEAM_DAY=6000          # advisory team SGT-day result cap
DISCOVERY_PROFILES_PER_USER_DAY=200          # atomic per-user SGT-day IG profile cap
DISCOVERY_PROFILES_PER_TEAM_DAY=500          # advisory team SGT-day IG profile cap
DISCOVERY_COST_PER_RESULT_USD=0.007          # rough pre-run estimate; actual read from the run
DISCOVERY_RECONCILE_STUCK_MINUTES=10         # age before a non-terminal run is re-fetched from Apify
DISCOVERY_CANDIDATE_TTL_DAYS=90              # retention: purge scraped candidates after N days (0 = keep forever)

# ── Redeem Ops — Outreach cadences (sequencing engine; migration 057) ──────────
REDEEM_OPS_CADENCES_ENABLED=false             # routes + hook wiring + seeds + reconcile tick (needs REDEEM_OPS_ENABLED too)
REDEEM_OPS_CADENCE_CAP=60                     # max live enrollments per owner (managers may override per-enroll)

# Consent ledger (PR B)
# Dedicated unsubscribe-token secret (optional; falls back to JWT_SECRET with a context salt — rotating whichever is in use invalidates outstanding unsubscribe links)
UNSUB_TOKEN_SECRET=
# Public API origin baked into unsubscribe links (default https://api.mktr.sg)
API_PUBLIC_ORIGIN=
